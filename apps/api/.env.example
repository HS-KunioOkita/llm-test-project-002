# PostgreSQL 接続文字列
DATABASE_URL=postgresql://app:app@localhost:5432/wholesale?schema=public

# HTTP サーバ
PORT=3000
HOST=0.0.0.0

# Cookie 署名用シークレット (最低 32 文字)
COOKIE_SECRET=change_me_to_a_sufficiently_long_random_value

# セッション有効期限 (秒) — 既定 8 時間
SESSION_TTL_SECONDS=28800

# 開発モード
NODE_ENV=development
